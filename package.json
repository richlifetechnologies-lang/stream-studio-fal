{
  "name": "stream-studio-fal",
  "version": "1.0.9",
  "description": "Stream Studio powered by fal.ai ÃÂÃÂ Decart Lucy 2.1 ÃÂ¢ÃÂÃÂ no watermark",
  "main": "dist-electron/main.js",
  "author": "Rich Life Technologies",
  "private": true,
  "scripts": {
    "dev": "concurrently \"vite\" \"nodemon --watch dist/index.html --exec 'electron .'\"",
    "build:web": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:web && npm run build:electron",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:mac": "npm run build && electron-builder --mac",
    "preview": "vite preview",
    "dist:mac:arm64": "npm run build && electron-builder --mac --arm64",
    "dist:mac:intel": "npm run build && electron-builder --mac --x64"
  },
  "dependencies": {
    "@fal-ai/client": "^1.10.1",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "wouter": "^3.3.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.1.9",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.6"
  },
  "build": {
    "appId": "com.richlife.streamstudiofal",
    "productName": "Stream Studio FAL",
    "copyright": "Copyright ÃÂÃÂ© 2025 Rich Life Technologies",
    "directories": {
      "output": "release",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "artifactName": "StreamStudio-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerSidebar": "public/installer-sidebar.bmp",
      "uninstallerSidebar": "public/installer-sidebar.bmp",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Stream Studio FAL",
      "displayLanguageSelector": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "category": "public.app-category.video",
      "artifactName": "StreamStudio-${version}-${arch}.dmg"
    },
    "linux": {
      "target": "AppImage",
      "category": "Video",
      "artifactName": "StreamStudio-${version}.AppImage"
    },
    "publish": {
      "provider": "github",
      "owner": "richlifetechnologies-lang",
      "repo": "stream-studio-fal"
    }
  }
}
